{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"types": [
			"vite-plugin-glsl/ext.d.ts",
			"vite/client",
			"leva",
			"three",
			"@react-three/fiber",
			"@react-three/drei",
			"vite-plugin-glsl",
			"@vitejs/plugin-react"
		],
		"outDir": "dist",
		"rootDir": ".",
		"allowJs": true,
		"skipLibCheck": false,
		"esModuleInterop": false,
		"allowSyntheticDefaultImports": true,
		"strict": false,
		"forceConsistentCasingInFileNames": true,
		"module": "ESNext",
		"moduleResolution": "Node",
		"strictNullChecks": false,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react"
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"leva.config.ts",
		"vite.config.ts"
	],
	"exclude": ["node_modules"]
}
