{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"files": {
		"ignore": ["dist", "node_modules", "biome.json", "pnpm-lock.yaml"],
		"include": ["src"]
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineEnding": "lf",
		"lineWidth": 120,
		"attributePosition": "auto",
		"bracketSpacing": true
	},
	"linter": {
		"enabled": true,
		"include": ["**/*.js", "**/*.jsx", "**/*.ts", "**/*.tsx"],
		"ignore": ["dist/*", "node_modules/*"],
		"rules": {
			"complexity": {
				"all": true
			},
			"a11y": {
				"all": true
			},
			"performance": {
				"all": true
			},
			"security": {
				"all": true
			},
			"style": {
				"all": true,
				"noImplicitBoolean": "off",
				"useNamingConvention": "off"
			},
			"correctness": {
				"all": true,
				"useImportExtensions": "off"
			},
			"nursery": {
				"recommended": true
			},
			"suspicious": {
				"all": true,
				"noReactSpecificProps": "off"
			}
		}
	},
	"css": {
		"formatter": {
			"indentStyle": "tab",
			"lineEnding": "lf",
			"lineWidth": 120,
			"indentWidth": 2
		}
	},
	"javascript": {
		"formatter": {
			"jsxQuoteStyle": "double",
			"quoteProperties": "asNeeded",
			"trailingCommas": "es5",
			"semicolons": "always",
			"arrowParentheses": "always",
			"bracketSpacing": true,
			"bracketSameLine": false,
			"quoteStyle": "double",
			"attributePosition": "auto"
		}
	},
	"json": {
		"formatter": {
			"indentStyle": "tab",
			"lineEnding": "lf",
			"lineWidth": 80,
			"trailingCommas": "none",
			"indentWidth": 2
		}
	}
}
